{% extends 'base.html.twig' %}

{% block title %}Mon panier - Knowledge Learning{% endblock %}

{% block body %}
    <div class="container my-5">
        <h1 class="mb-4">
            <i class="bi bi-cart"></i> Mon panier
        </h1>

        {% if cart.items.isEmpty() %}
            <div class="alert alert-info">
                <i class="bi bi-info-circle"></i> Votre panier est vide.
            </div>
            <a href="{{ path('app_home') }}" class="btn btn-primary">
                <i class="bi bi-arrow-left"></i> Continuer mes achats
            </a>
        {% else %}
            <div class="table-responsive mb-4">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                    <tr>
                        <th>Élément</th>
                        <th>Type</th>
                        <th class="text-end">Prix</th>
                        <th class="text-end">Actions</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for item in items %}
                        <tr>
                            <td>{{ item.label }}</td>
                            <td>
                                <span class="badge bg-{{ item.badgeClass }}">{{ item.typeLabel }}</span>
                            </td>
                            <td class="text-end">{{ item.formattedPrice }}</td>
                            <td class="text-end">
                                <form action="{{ path('app_cart_remove_item', {id: item.id}) }}" method="post">
                                    <input type="hidden" name="_token" value="{{ csrf_token('cart_remove_item' ~ item.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger" title="Retirer">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    {% endfor %}
                    </tbody>
                    <tfoot class="table-light">
                    <tr>
                        <th colspan="2"><strong>Total</strong></th>
                        <th class="text-end"><strong>{{ totalFormatted }}</strong></th>
                        <th></th>
                    </tr>
                    </tfoot>
                </table>
            </div>

            <div class="d-flex justify-content-between flex-wrap gap-3">
                <a href="{{ path('app_home') }}" class="btn btn-outline-secondary">
                    <i class="bi bi-arrow-left"></i> Continuer mes achats
                </a>
                <div>
                    <form action="{{ path('app_cart_clear') }}" method="post" class="d-inline me-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_clear') }}">
                        <button type="submit" class="btn btn-outline-danger">
                            <i class="bi bi-trash"></i> Vider le panier
                        </button>
                    </form>
                    <form action="{{ path('app_cart_checkout') }}" method="post" class="d-inline" data-turbo="false">
                        <input type="hidden" name="_token" value="{{ csrf_token('cart_checkout') }}">
                        <button type="submit" class="btn btn-primary btn-lg">
                            <i class="bi bi-credit-card"></i> Procéder au paiement {{ totalFormatted }}
                        </button>
                    </form>
                </div>
            </div>
        {% endif %}
    </div>
{% endblock %}
