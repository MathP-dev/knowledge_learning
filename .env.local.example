# Mailer (mailpit en local)
MAILER_DSN=smtp://localhost:1025

# Stripe - Clés de TEST (à remplacer par vos clés)
STRIPE_PUBLIC_KEY=pk_test_VOTRE_CLE_PUBLIQUE
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_SECRETE
